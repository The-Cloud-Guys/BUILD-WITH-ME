{
  "info": {
    "name": "Build With Me - Full API (Auth + Onboarding + Profile + Projects + Community)",
    "description": "Complete test suite for authentication, onboarding, profile (combined), projects (role-based CRUD, applications, team, featured & recommended), community, and negative tests. Uses HTTP-only cookies – Postman manages them automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5050" },
    { "key": "testEmail", "value": "postman@example.com" },
    { "key": "testPassword", "value": "test1234" },
    { "key": "testFirstName", "value": "John" },
    { "key": "testLastName", "value": "Doe" },
    { "key": "testBio", "value": "Passionate full-stack developer." },
    { "key": "testExternalLink", "value": "https://github.com/johndoe" },
    { "key": "newPassword", "value": "newpass5678" },
    { "key": "resetOtp", "value": "", "description": "Copy from password reset OTP email (6 digits)" },
    { "key": "resetToken", "value": "", "description": "Temporary JWT returned by /verify-reset-otp" },
    { "key": "verificationOtp", "value": "", "description": "Copy from email OTP (6 digits)" },
    { "key": "firebaseIdToken", "value": "", "description": "Obtain from frontend Google sign-in" },
    { "key": "projectId", "value": "", "description": "ID of created project" },
    { "key": "applicationId", "value": "", "description": "ID of submitted application" },
    { "key": "postId", "value": "", "description": "ID of created post" },
    { "key": "commentId", "value": "", "description": "ID of created comment" },
    { "key": "targetUserId", "value": "", "description": "ID of another user (for follow tests)" }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "1. Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response contains message and email', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message').that.includes('Registration successful');",
                  "  pm.expect(jsonData).to.have.property('email', pm.variables.get('testEmail'));",
                  "});",
                  "console.log('✅ Registration successful. Set variable \"verificationOtp\" from email/terminal.');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "2. Verify Email OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains accessToken and refreshToken', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('accessToken');",
                  "  pm.expect(jsonData).to.have.property('refreshToken');",
                  "  pm.expect(jsonData.user).to.have.property('email', pm.variables.get('testEmail'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"otp\": \"{{verificationOtp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-email"]
            }
          }
        },
        {
          "name": "3. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains user data and tokens', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('accessToken');",
                  "  pm.expect(jsonData).to.have.property('refreshToken');",
                  "  pm.expect(jsonData.user).to.have.property('email', pm.variables.get('testEmail'));",
                  "});",
                  "pm.test('Cookies are set', () => {",
                  "  const setCookieHeaders = pm.response.headers.all().filter(h => h.key === 'Set-Cookie');",
                  "  const cookiesString = setCookieHeaders.map(h => h.value).join('; ');",
                  "  pm.expect(cookiesString).to.include('accessToken');",
                  "  pm.expect(cookiesString).to.include('refreshToken');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "4. Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns user profile without password', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('email', pm.variables.get('testEmail'));",
                  "  pm.expect(jsonData).to.not.have.property('password');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
