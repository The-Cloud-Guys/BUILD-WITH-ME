          }
        },
        {
          "name": "18. Delete Profile Photo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Photo deleted successfully', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message', 'Profile photo deleted successfully');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/profile/me/photo",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "me", "photo"]
            }
          }
        }
      ]
    },
    {
      "name": "🚀 Projects",
      "item": [
        {
          "name": "19. Create Project",
          "event": [
            {
              "listen": "test",
