{
  "info": {
    "name": "Build With Me - Full API (Auth + Onboarding + Profile + Storage)",
    "description": "Complete test suite for authentication (register, OTP, login, refresh, logout, password reset OTP, Firebase), step‑by‑step onboarding (role, skills, profile completion), profile management (update, photo upload & delete with signed URLs), and negative tests. Uses HTTP‑only cookies – Postman manages them automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5050" },
    { "key": "testEmail", "value": "postman@example.com" },
    { "key": "testPassword", "value": "test1234" },
    { "key": "testFirstName", "value": "John" },
    { "key": "testLastName", "value": "Doe" },
    { "key": "testBio", "value": "Passionate full‑stack developer." },
    { "key": "testExternalLink", "value": "https://github.com/johndoe" },
    { "key": "newPassword", "value": "newpass5678" },
    { "key": "resetOtp", "value": "", "description": "Copy from password reset OTP email (6 digits)" },
    { "key": "verificationOtp", "value": "", "description": "Copy from email OTP (6 digits)" },
    { "key": "firebaseIdToken", "value": "", "description": "Obtain from frontend Google sign‑in" }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "1. Register User (email + password only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response contains message and email', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message').that.includes('Registration successful');",
                  "  pm.expect(jsonData).to.have.property('email', pm.variables.get('testEmail'));",
                  "});",
                  "console.log('✅ Registration successful. Set variable \"verificationOtp\" from email/terminal.');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "2. Verify Email OTP (manual OTP entry)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains success message and user data', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Email verified successfully');",
                  "  pm.expect(jsonData).to.have.property('user');",
                  "  pm.expect(jsonData.user).to.have.property('email', pm.variables.get('testEmail'));",
                  "  pm.expect(jsonData.user).to.have.property('onboardingStep', 0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"otp\": \"{{verificationOtp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-email"]
            },
            "description": "⚠️ Set collection variable 'verificationOtp' before running."
          }
        },
        {
          "name": "3. Login (sets cookies)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains user data and no token (cookie only)', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Login successful');",
                  "  pm.expect(jsonData).to.have.property('user');",
                  "  pm.expect(jsonData.user).to.have.property('email', pm.variables.get('testEmail'));",
                  "  pm.expect(jsonData).to.not.have.property('token');",
                  "});",
                  "pm.test('Cookies are present in response headers', () => {",
                  "  const setCookieHeaders = pm.response.headers.all().filter(h => h.key === 'Set-Cookie');",
                  "  const cookiesString = setCookieHeaders.map(h => h.value).join('; ');",
                  "  pm.expect(cookiesString).to.include('accessToken');",
                  "  pm.expect(cookiesString).to.include('refreshToken');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "4. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Refreshed tokens set new cookies', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message', 'Token refreshed');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh-token"]
            }
          }
        },
        {
          "name": "5. Logout (clears cookies)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Logout success message', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message', 'Logged out');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        },
        {
          "name": "6. Forgot Password (request OTP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Reset OTP sent confirmation', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message');",
                  "});",
                  "console.log('✅ Password reset OTP sent. Set variable \"resetOtp\" from email/terminal.');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "forgot-password"]
            }
          }
        },
        {
          "name": "7. Reset Password (using OTP, returns cookies)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Password reset sets new cookies and returns user', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Password reset successful');",
                  "  pm.expect(jsonData).to.have.property('user');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"otp\": \"{{resetOtp}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password"]
            },
            "description": "⚠️ Set collection variable 'resetOtp' from the password reset email (6-digit code)."
          }
        },
        {
          "name": "8. Firebase Google Auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Firebase login sets cookies', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Firebase login successful');",
                  "  pm.expect(jsonData).to.have.property('user');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{firebaseIdToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/firebase",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "firebase"]
            },
            "description": "⚠️ Obtain Firebase ID token from frontend and set variable 'firebaseIdToken'."
          }
        }
      ]
    },
    {
      "name": "📝 Onboarding Flow",
      "item": [
        {
          "name": "9. Get Onboarding Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains onboardingStep', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('onboardingStep');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "onboarding", "status"]
            }
          }
        },
        {
          "name": "10. Set User Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response shows next step and role', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Role saved successfully');",
                  "  pm.expect(jsonData).to.have.property('nextStep', 'skills');",
                  "  pm.expect(jsonData.user).to.have.property('role', 'Developer');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"Developer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/role",
              "host": ["{{baseUrl}}"],
              "path": ["api", "onboarding", "role"]
            }
          }
        },
        {
          "name": "11. Set User Skills",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response shows next step and skills', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Skills saved successfully');",
                  "  pm.expect(jsonData).to.have.property('nextStep', 'profile');",
                  "  pm.expect(jsonData.user.skills).to.be.an('array').that.includes('Node.js');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skills\": [\"Node.js\", \"React\", \"MongoDB\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/skills",
              "host": ["{{baseUrl}}"],
              "path": ["api", "onboarding", "skills"]
            }
          }
        },
        {
          "name": "12. Complete Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Profile completed successfully', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Profile completed successfully');",
                  "  pm.expect(jsonData).to.have.property('onboardingComplete', true);",
                  "  pm.expect(jsonData.user).to.have.property('firstName', pm.variables.get('testFirstName'));",
                  "  pm.expect(jsonData.user).to.have.property('lastName', pm.variables.get('testLastName'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"{{testFirstName}}\",\n  \"lastName\": \"{{testLastName}}\",\n  \"bio\": \"{{testBio}}\",\n  \"externalLink\": \"{{testExternalLink}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "onboarding", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "🖼️ Profile Management",
      "item": [
        {
          "name": "13. Get Current Profile (after onboarding)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Profile contains firstName, lastName, skills, etc.', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('firstName', pm.variables.get('testFirstName'));",
                  "  pm.expect(jsonData).to.have.property('skills').that.is.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/profile/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "me"]
            }
          }
        },
        {
          "name": "14. Update Profile (additional changes)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Profile updated successfully', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Profile updated successfully');",
                  "  pm.expect(jsonData.user).to.have.property('bio', 'Updated bio text');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Updated bio text\",\n  \"skills\": [\"Node.js\", \"React\", \"TypeScript\"],\n  \"externalLink\": \"https://johndoe.dev\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/profile/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "me"]
            }
          }
        },
        {
          "name": "15. Upload Profile Photo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains signed URL for photo', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Profile photo uploaded successfully');",
                  "  pm.expect(jsonData).to.have.property('profilePhoto').that.includes('signed');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "photo",
                  "type": "file",
                  "src": "/path/to/sample-avatar.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/profile/me/photo",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "me", "photo"]
            },
            "description": "⚠️ Replace '/path/to/sample-avatar.jpg' with an actual image file path on your computer."
          }
        },
        {
          "name": "16. Delete Profile Photo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Photo deleted successfully', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message', 'Profile photo deleted successfully');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/profile/me/photo",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "me", "photo"]
            }
          }
        }
      ]
    },
    {
      "name": "⚠️ Negative Tests",
      "item": [
        {
          "name": "17. Register with Existing Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error indicates email exists', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message', 'Email already exists');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"somepass\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "18. Login with Unverified Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error asks to verify email', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message', 'Please verify your email before logging in.');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "19. Access Protected Route Without Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error indicates no token', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message', 'Not authorized, no token');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/profile/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "me"]
            }
          }
        }
      ]
    }
  ]
}