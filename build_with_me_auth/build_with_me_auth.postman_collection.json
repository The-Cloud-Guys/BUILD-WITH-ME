{
  "info": {
    "name": "Build With Me - Full API (Auth + Onboarding + Profile + Storage + Projects)",
    "description": "Complete test suite for authentication, onboarding, profile, projects (CRUD, applications, team management), and negative tests. Uses HTTP‑only cookies – Postman manages them automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5050" },
    { "key": "testEmail", "value": "postman@example.com" },
    { "key": "testPassword", "value": "test1234" },
    { "key": "testFirstName", "value": "John" },
    { "key": "testLastName", "value": "Doe" },
    { "key": "testBio", "value": "Passionate full‑stack developer." },
    { "key": "testExternalLink", "value": "https://github.com/johndoe" },
    { "key": "newPassword", "value": "newpass5678" },
    { "key": "resetOtp", "value": "", "description": "Copy from password reset OTP email (6 digits)" },
    { "key": "resetToken", "value": "", "description": "Temporary JWT returned by /verify-reset-otp" },
    { "key": "verificationOtp", "value": "", "description": "Copy from email OTP (6 digits)" },
    { "key": "firebaseIdToken", "value": "", "description": "Obtain from frontend Google sign‑in" },
    { "key": "projectId", "value": "", "description": "ID of created project" },
    { "key": "applicationId", "value": "", "description": "ID of submitted application" }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "1. Register User (email + password only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response contains message and email', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message').that.includes('Registration successful');",
                  "  pm.expect(jsonData).to.have.property('email', pm.variables.get('testEmail'));",
                  "});",
                  "console.log('✅ Registration successful. Set variable \"verificationOtp\" from email/terminal.');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "2. Verify Email OTP (manual OTP entry)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains success message, user data, and accessToken', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Email verified successfully');",
                  "  pm.expect(jsonData).to.have.property('accessToken');",
                  "  pm.expect(jsonData).to.have.property('user');",
                  "  pm.expect(jsonData.user).to.have.property('email', pm.variables.get('testEmail'));",
                  "  pm.expect(jsonData.user).to.have.property('onboardingStep', 0);",
                  "  pm.expect(jsonData).to.have.property('onboardingStatus', 'email_verified');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"otp\": \"{{verificationOtp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-email"]
            },
            "description": "⚠️ Set collection variable 'verificationOtp' before running."
          }
        },
        {
          "name": "3. Login (sets cookies)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains user data, accessToken, and no token (cookie only)', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Login successful');",
                  "  pm.expect(jsonData).to.have.property('accessToken');",
                  "  pm.expect(jsonData).to.have.property('user');",
                  "  pm.expect(jsonData.user).to.have.property('email', pm.variables.get('testEmail'));",
                  "  pm.expect(jsonData.user).to.have.property('onboardingStep');",
                  "  pm.expect(jsonData).to.have.property('onboardingStatus');",
                  "  pm.expect(jsonData).to.not.have.property('token');",
                  "});",
                  "pm.test('Cookies are present in response headers', () => {",
                  "  const setCookieHeaders = pm.response.headers.all().filter(h => h.key === 'Set-Cookie');",
                  "  const cookiesString = setCookieHeaders.map(h => h.value).join('; ');",
                  "  pm.expect(cookiesString).to.include('accessToken');",
                  "  pm.expect(cookiesString).to.include('refreshToken');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "4. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Refreshed tokens set new cookies and return accessToken', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Token refreshed');",
                  "  pm.expect(jsonData).to.have.property('accessToken');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh-token"]
            }
          }
        },
        {
          "name": "5. Logout (clears cookies)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Logout success message', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message', 'Logged out');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        },
        {
          "name": "6. Forgot Password (request OTP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Reset OTP sent confirmation', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message');",
                  "});",
                  "console.log('✅ Password reset OTP sent. Set variable \"resetOtp\" from email/terminal.');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "forgot-password"]
            }
          }
        },
        {
          "name": "7. Verify Reset OTP (returns temporary token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains resetToken', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('resetToken');",
                  "  pm.collectionVariables.set('resetToken', jsonData.resetToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"otp\": \"{{resetOtp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-reset-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-reset-otp"]
            },
            "description": "⚠️ Set variable 'resetOtp' before running. The response contains a short-lived JWT (resetToken) used in the next step."
          }
        },
        {
          "name": "8. Reset Password (using token, returns cookies)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Password reset sets new cookies, returns user and accessToken', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Password reset successful');",
                  "  pm.expect(jsonData).to.have.property('accessToken');",
                  "  pm.expect(jsonData).to.have.property('user');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password"]
            },
            "description": "⚠️ This step uses the resetToken obtained from /verify-reset-otp (automatically set as collection variable)."
          }
        },
        {
          "name": "9. Firebase Google Auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Firebase login returns token and isProfileCompleted', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Firebase login successful');",
                  "  pm.expect(jsonData).to.have.property('token');",
                  "  pm.expect(jsonData).to.have.property('isProfileCompleted');",
                  "  pm.expect(jsonData).to.have.property('user');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{firebaseIdToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/firebase",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "firebase"]
            },
            "description": "⚠️ Obtain Firebase ID token from frontend and set variable 'firebaseIdToken'."
          }
        }
      ]
    },
    {
      "name": "📝 Onboarding Flow",
      "item": [
        {
          "name": "10. Get Onboarding Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains onboardingStep', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('onboardingStep');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "onboarding", "status"]
            }
          }
        },
        {
          "name": "11. Set User Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response shows next step and role', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Role saved successfully');",
                  "  pm.expect(jsonData).to.have.property('nextStep', 'skills');",
                  "  pm.expect(jsonData.user).to.have.property('role', 'Developer');",
                  "  pm.expect(jsonData).to.have.property('onboardingStatus', 'role_pending');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"Developer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/role",
              "host": ["{{baseUrl}}"],
              "path": ["api", "onboarding", "role"]
            }
          }
        },
        {
          "name": "12. Set User Skills",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response shows next step and skills', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Skills saved successfully');",
                  "  pm.expect(jsonData).to.have.property('nextStep', 'profile');",
                  "  pm.expect(jsonData.user.skills).to.be.an('array').that.includes('Node.js');",
                  "  pm.expect(jsonData).to.have.property('onboardingStatus', 'skills_pending');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skills\": [\"Node.js\", \"React\", \"MongoDB\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/skills",
              "host": ["{{baseUrl}}"],
              "path": ["api", "onboarding", "skills"]
            }
          }
        },
        {
          "name": "13. Complete Profile (text only) - using /onboarding/profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Profile completed successfully', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Profile completed successfully');",
                  "  pm.expect(jsonData).to.have.property('onboardingComplete', true);",
                  "  pm.expect(jsonData.user).to.have.property('firstName', pm.variables.get('testFirstName'));",
                  "  pm.expect(jsonData.user).to.have.property('lastName', pm.variables.get('testLastName'));",
                  "  pm.expect(jsonData).to.have.property('onboardingStatus', 'completed');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"{{testFirstName}}\",\n  \"lastName\": \"{{testLastName}}\",\n  \"bio\": \"{{testBio}}\",\n  \"externalLink\": \"{{testExternalLink}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "onboarding", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "🖼️ Combined Profile + Photo Endpoints",
      "item": [
        {
          "name": "14a. Create Full Profile with Photo (multipart) - POST /api/userProfile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Profile created with photo and details', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Profile created successfully');",
                  "  pm.expect(jsonData).to.have.property('onboardingCompleted', true);",
                  "  pm.expect(jsonData).to.have.property('onboardingStatus', 'completed');",
                  "  pm.expect(jsonData.user).to.have.property('firstName', pm.variables.get('testFirstName'));",
                  "  pm.expect(jsonData.user).to.have.property('lastName', pm.variables.get('testLastName'));",
                  "  pm.expect(jsonData.user).to.have.property('profilePhoto').that.includes('signed');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "firstName", "value": "{{testFirstName}}", "type": "text" },
                { "key": "lastName", "value": "{{testLastName}}", "type": "text" },
                { "key": "bio", "value": "{{testBio}}", "type": "text" },
                { "key": "externalLink", "value": "{{testExternalLink}}", "type": "text" },
                { "key": "photo", "type": "file", "src": "/path/to/sample-avatar.jpg" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/profile/userProfile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "userProfile"]
            },
            "description": "⚠️ Replace '/path/to/sample-avatar.jpg' with an actual image file path."
          }
        },
        {
          "name": "14b. Update Full Profile with Photo (multipart) - PATCH /api/userProfile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Profile updated with photo and details', () => {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('message', 'Profile updated successfully');",
                  "  pm.expect(jsonData.user).to.have.property('bio', 'Updated bio via multipart');",
                  "  pm.expect(jsonData.user).to.have.property('profilePhoto').that.includes('signed');",
                  "  pm.expect(jsonData).to.have.property('onboardingStatus');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "bio", "value": "Updated bio via multipart", "type": "text" },
                { "key": "skills", "value": "TypeScript,GraphQL", "type": "text" },
                { "key": "externalLink", "value": "https://updated.dev", "type": "text" },
                { "key": "photo", "type": "file", "src": "/path/to/new-avatar.jpg" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/profile/userProfile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile", "userProfile"]
            },
            "description": "⚠️ Replace file path with actual image."
          }
        }
      ]
    },
